# Default pool address for leaderboard
# Default: SOL-USDC pool
DEFAULT_POOL=5rCf1DM8LjKTw4YqhnoLcngyZYeNnQqztScTogYHAS6

# Web dashboard port
PORT=7777

# More positions means slower but more complete rankings
MAX_POSITIONS_PER_POOL=100

# Keep below 10 to avoid rate limits
CONCURRENCY=5

# Cache TTL in seconds
CACHE_TTL=300

# Strongly recommended. Public Solana RPC often rate-limits getProgramAccounts.
# If set, SOLANA_RPC_URL can be omitted.
HELIUS_API_KEY=

# Optional custom Solana RPC endpoint for on-chain position discovery
SOLANA_RPC_URL=
