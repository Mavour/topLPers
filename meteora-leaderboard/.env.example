# Telegram Bot Token
TELEGRAM_BOT_TOKEN=

# Default pool address for leaderboard
# Default: SOL-USDC pool
DEFAULT_POOL=5rCf1DM8LjKTw4YqhnoLcngyZYeNnQqztScTogYHAS6

# More positions means slower but more complete rankings
MAX_POSITIONS_PER_POOL=100

# Keep below 10 to avoid rate limits
CONCURRENCY=5

# Cache TTL in seconds
CACHE_TTL=300

# Comma-separated Telegram user IDs. Empty means open access.
ALLOWED_USER_IDS=

# Optional RPC backup key for future extensions
HELIUS_API_KEY=

# Optional Solana RPC endpoint for on-chain position discovery
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
