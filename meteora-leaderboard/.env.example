PORT=3001

# Berapa banyak top pools yang diindex (lebih banyak = lebih lama, lebih lengkap)
TOP_POOLS_LIMIT=50

# Max posisi yang diproses per pool
MAX_POSITIONS_PER_POOL=200

# Concurrent requests ke Meteora API (max 10 untuk hindari rate limit 30rps)
CONCURRENCY=6

# Cron schedule untuk auto-reindex (default: tiap 1 jam)
CRON_SCHEDULE=0 * * * *

# Secret token untuk trigger manual reindex via POST /api/index/run
ADMIN_TOKEN=ganti_ini_dengan_random_string

# Path database SQLite
DB_PATH=./leaderboard.db

# Optional: custom RPC untuk fallback position discovery
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
