# Web server port
PORT=3000

# Helius RPC (optional, for future on-chain enrichment)
HELIUS_API_KEY=your_helius_key_here

# SOL price override (optional, default: fetch from Jupiter)
# SOL_PRICE_OVERRIDE=150

# Default period for leaderboard (7, 30, 90, all)
DEFAULT_PERIOD=7

# Max results per query
DEFAULT_LIMIT=20

# Cache TTL in seconds
CACHE_TTL_SECONDS=300
